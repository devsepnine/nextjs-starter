{
  "name": "starter-pack",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm lingui:extract_and_compile && next build --webpack",
    "start": "next start",
    "clean": "rm -rf .next",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm lint:fix",
    "lint:fix": "npx eslint --fix",
    "format": "prettier --write .",
    "analyze": "ANALYZE=true npm run build",
    "lingui:extract": "lingui extract --clean",
    "lingui:compile": "lingui compile --typescript",
    "lingui:watch": "lingui extract --watch",
    "lingui:extract_and_compile": "pnpm run lingui:extract && pnpm run lingui:compile",
    "prepare": "husky"
  },
  "type": "module",
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "@js-temporal/polyfill": "^0.5.1",
    "@lingui/core": "^6.0.1",
    "@lingui/loader": "^6.0.1",
    "@lingui/macro": "^5.9.5",
    "@lingui/react": "^6.0.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@serwist/next": "^9.5.11",
    "@tailwindcss/postcss": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next": "^16.2.6",
    "postcss": "^8.5.14",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@hibicanvas/prettier-config": "^1.0.57",
    "@lingui/cli": "^6.0.1",
    "@lingui/format-po": "^6.0.1",
    "@next/bundle-analyzer": "^16.2.6",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "serwist": "^9.5.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  },
  "volta": {
    "node": "24.11.0"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "not dead"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.14",
      "webpack": "^5.106.2"
    }
  }
}
